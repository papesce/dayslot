{
  "name": "@papesce/dayslot",
  "version": "0.3.2",
  "description": "Embeddable drag-and-drop daily timeline React component",
  "type": "module",
  "main": "./dist/dayslot.umd.cjs",
  "module": "./dist/dayslot.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/dayslot.js",
      "require": "./dist/dayslot.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "keywords": [
    "react",
    "timeline",
    "calendar",
    "drag-drop",
    "scheduler",
    "daily-planner"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/papesce/dayslot.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npx tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
