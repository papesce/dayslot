{
  "name": "dayslot",
  "version": "0.1.0",
  "description": "Embeddable drag-and-drop daily timeline React component",
  "type": "module",
  "main": "./dist/dayslot.umd.cjs",
  "module": "./dist/dayslot.js",
  "exports": {
    ".": {
      "import": "./dist/dayslot.js",
      "require": "./dist/dayslot.umd.cjs"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "keywords": ["react", "timeline", "calendar", "drag-drop", "scheduler", "daily-planner"],
  "repository": {
    "type": "git",
    "url": "https://github.com/papesce/dayslot"
  },
  "license": "MIT",
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
